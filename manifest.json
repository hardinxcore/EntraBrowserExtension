{
  "manifest_version": 3,
  "name": "Entra Favorites & Sorter",
  "version": "1.1.0",
  "description": "Bookmark Microsoft Entra Apps, Groups, and Users. Automatically sort Entra left menus alphabetically.",
  "permissions": [
    "activeTab",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://entra.microsoft.com/*",
    "https://intune.microsoft.com/*",
    "https://endpoint.microsoft.com/*"
  ],
  "content_scripts": [
    {
      "all_frames": true,
      "matches": [
        "*://entra.microsoft.com/*",
        "*://portal.azure.com/*",
        "*://aad.portal.azure.com/*",
        "*://admin.microsoft.com/*",
        "*://intune.microsoft.com/*",
        "*://endpoint.microsoft.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    },
    {
      "all_frames": true,
      "matches": ["*://*.reactblade.portal.azure.net/*"],
      "js": ["iframe-content-v2.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "omnibox": {
    "keyword": "entra"
  },
  "commands": {
    "add-favorite": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Add current Entra page to favorites"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Entra Favorites",
    "default_icon": "icons/icon48.png"
  }
}
